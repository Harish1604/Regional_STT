# ============================================================
# Regional STT Chatbot — Backend Environment Variables
# ============================================================

# --- HuggingFace (required for AI4Bharat model download) ---
HF_TOKEN=your_huggingface_token_here

# --- STT Configuration ---
STT_MODEL_NAME=ai4bharat/indic-conformer-600m-multilingual
STT_DEVICE=auto
STT_DECODE_MODE=rnnt

# --- Audio Preprocessing ---
AUDIO_NORMALIZE=true
AUDIO_HIGH_PASS_CUTOFF=100
AUDIO_SILENCE_STRIP=true
AUDIO_NOISE_GATE_ENABLED=true
AUDIO_NOISE_GATE_THRESHOLD=-40.0

# --- LLM Provider (ollama | gemini | openai) ---
LLM_PROVIDER=ollama

# --- Ollama (default — local Llama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Google Gemini (if using Gemini provider) ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (if using OpenAI provider) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Server ---
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000

# --- Supported Languages (comma-separated) ---
SUPPORTED_LANGUAGES=ta,hi,te,ml,kn,bn,gu,mr,pa,ur
